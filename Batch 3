import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.awt.event.ActionEvent.*;
import java.awt.event.ActionListener.*;
import java.util.ArrayList;

/*
Weekly expense tracker
 */

public class App extends JFrame
{
    // Dropdown Menu for Days 
    private JComboBox<String> dayBox;

    // DropDown Menu for Categories 
    private JComboBox<String> categoryBox;

    // Text feild for amount 
    private JTextField amountFeild;

    // Text feild for description 
    private JTextField descriptionFeild;

    // Text area to display output
    private JTextArea outputArea;

    // ArrayList to store all expenses 
    private ArrayList<Expense> expenses = new ArrayList<>();

    // Constructor
    public App()
    {
        // Window Title 
        setTitle("Weekly Expense Tracker");

        // Window Size 
        setSize(700,500);

        // Close application on exit 
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        // Center Window on screen 
        setLocationRelativeTo(null);

        // Main Panel 
        JPanel panel = new JPanel();
        panel.setLayout(new GridLayout(7,2,10,10)); 

        // Days dropdown
        String[] days = {
            "Monday","Tuesday","Wednesday","Thursday","Fridays","Saturday","Sunday" 
        };

        dayBox = new JComboBox<>(days);

        // Categories dropdown
        String[] categories = {
            "Groceries","Eating out","Petrol","Taxi","Bills","Rent","Others"
        };

        categoryBox =  new JComboBox<>(categories);

        // Amount input 
        amountFeild = new JTextField();

        // Description input 
        descriptionFeild = new JTextField();

        // Buttons 
        JButton addButton = new JButton("Add Expesne");
        JButton totalButton = new JButton("Total Weekly Expense");
        JButton viewButton = new JButton("View Expense by Categories");

        // Output
        outputArea = new JTextArea();
        outputArea.setEditable(false);

        JScrollPane scrollPane = new JScrollPane(outputArea);

        // Add to panel 
        panel.add(new JLabel("Select Day"));
        panel.add(dayBox);

        panel.add(new JLabel("Select Category"));
        panel.add(categoryBox);

        panel.add(new JLabel("Enter Amount"));
        panel.add(amountFeild);

        panel.add(new JLabel("Description"));
        panel.add(descriptionFeild);

        panel.add(addButton);

        panel.add(totalButton);

        panel.add(viewButton);


        panel.add(new JLabel(""));

        // adding output and panel
        add(panel, BorderLayout.NORTH);
        add(scrollPane, BorderLayout.CENTER);

        // Expense Button

        addButton.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {

                try {
                    // Selected Values
                    String day = dayBox.getSelectedItem().toString();
                    String category = categoryBox.getSelectedItem().toString();

                    // Get Amount 
                    double amount = Double.parseDouble(amountFeild.getText());

                    // Get Description 
                    String description = descriptionFeild.getText();

                    // Validation
                    if (amount<=0)
                    {
                        JOptionPane.showMessageDialog(null, "Amount must be more than 0");
                        return;
                    }

                    if (description.trim().isEmpty())
                    {
                        JOptionPane.showMessageDialog(null, "Description cant be empty");
                        return;
                    }
                    // Expense Object
                    Expense expense = new Expense(day, category, amount, description);  

                    // Add to ArrayList
                    expense.add(expense);

                    // Success message 
                    JOptionPane.showMessageDialog(null, "Expense added Successfully");

                    // Clear Feilds
                    amountFeild.setText("");
                    descriptionFeild.setText("");
                }

                // Valid number input
                catch(NumberFormatException ex)
                {
                    JOptionPane.showMessageDialog(null, "Enter Valid Amount");
                }

                // Handle any other error 
                catch (Exception ex)
                {
                    JOptionPane.showConfirmDialog(null, "Error");
                }

    }

});

    // EXPENSE BUTTON
    
}

}
